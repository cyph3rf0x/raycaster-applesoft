10 REM LOW-RES 3D RAYCASTER
20 GR : DIM M(10,10)
30 GOSUB 1000 : REM LOAD MAP
40 PX = 2.5 : PY = 2.5 : PA = 0
50 FOV = 1.047 : STP = 0.15
60 REM --- MAIN RENDER LOOP ---
70 FOR S = 0 TO 39
80 RA = PA - (FOV / 2) + (S / 39) * FOV
90 RX = PX : RY = PY
100 DX = COS(RA) * STP : DY = SIN(RA) * STP
110 D = 0 : HB = 0 : REM HB IS HAS-BARREL FLAG
120 RX = RX + DX : RY = RY + DY : D = D + STP
130 W = M(INT(RX), INT(RY))
140 IF W = 0 THEN GOTO 120
150 IF W <> 3 THEN GOTO 190
160 FX = RX - INT(RX) : FY = RY - INT(RY) : REM FIND FRACTIONAL POSITION
170 IF FX > 0.4 AND FX < 0.6 AND FY > 0.4 AND FY < 0.6 AND HB = 0 THEN HB = 1 : BD = D
180 GOTO 120 : REM KEEP CASTING THROUGH BARREL
190 D = D * COS(RA - PA) : REM MAIN WALL FISHEYE
200 IF D < 0.1 THEN D = 0.1
210 H = INT(15 / D) : IF H > 19 THEN H = 19
220 T = 19 - H : BT = 19 + H
230 IF T > 0 THEN COLOR= 5 : VLIN 0, T - 1 AT S : REM CEILING
240 IF BT < 39 THEN COLOR= 15 : VLIN BT + 1, 39 AT S : REM FLOOR
250 IF W = 1 THEN COLOR= 2 : REM DARK BLUE WALL
252 IF W = 2 THEN COLOR= 14 : REM EXIT
254 IF W = 4 THEN COLOR= 1 : REM RED WALL
256 IF W = 5 THEN COLOR= 3 : REM PURPLE WALL
258 IF W = 6 THEN COLOR= 6 : REM MEDIUM BLUE WALL
270 VLIN T, BT AT S
280 IF HB = 0 THEN GOTO 330 : REM SKIP IF NO BARREL HIT
290 BD = BD * COS(RA - PA) : IF BD < 0.1 THEN BD = 0.1
300 BH = INT(15 / BD) : IF BH > 19 THEN BH = 19
310 BT = 19 + BH : T = BT - INT((BH * 2) / 3) : REM CALCULATE 1/3 HEIGHT
320 COLOR= 12 : VLIN T, BT AT S : REM DRAW THINNER GREEN BARREL OVERLAY
330 NEXT S
340 REM --- INPUT LOOP ---
350 GET A$
360 IF A$ = "A" THEN PA = PA - 0.25 : GOTO 70
370 IF A$ = "D" THEN PA = PA + 0.25 : GOTO 70
380 IF A$ = "W" THEN NX = PX + COS(PA)*0.5 : NY = PY + SIN(PA)*0.5
390 IF A$ = "W" AND M(INT(NX), INT(NY)) = 2 THEN GOTO 2000
400 IF A$ = "W" AND M(INT(NX), INT(NY)) = 0 THEN PX = NX : PY = NY : GOTO 70
410 IF A$ = "S" THEN NX = PX - COS(PA)*0.5 : NY = PY - SIN(PA)*0.5
420 IF A$ = "S" AND M(INT(NX), INT(NY)) = 2 THEN GOTO 2000
430 IF A$ = "S" AND M(INT(NX), INT(NY)) = 0 THEN PX = NX : PY = NY : GOTO 70
440 GOTO 350
1000 REM --- LOAD MAP DATA ---
1010 FOR Y = 1 TO 10 : FOR X = 1 TO 10
1020 READ V : M(X,Y) = V
1030 NEXT X, Y : RETURN
1040 DATA 4,4,4,4,4,4,4,4,4,4
1050 DATA 4,0,0,0,0,0,0,0,0,5
1060 DATA 4,0,0,0,6,0,0,0,0,5
1070 DATA 4,0,0,3,6,3,0,0,0,5
1080 DATA 4,0,6,6,6,6,6,0,0,5
1090 DATA 4,0,0,3,6,3,0,0,0,5
1100 DATA 4,0,0,0,6,0,0,0,0,5
1110 DATA 4,0,1,0,0,0,0,1,0,5
1120 DATA 4,0,0,0,0,0,0,0,0,5
1130 DATA 4,1,1,1,2,1,1,1,1,5
2000 TEXT : HOME : VTAB 10 : HTAB 10 : PRINT "YOU ESCAPED!" : END