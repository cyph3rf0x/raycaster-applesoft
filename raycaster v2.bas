10 REM LOW-RES 3D RAYCASTER V2
20 GR : DIM M(10,10),CO(39),SN(39),CL(6)
30 RX = 0:RY = 0:DX = 0:DY = 0:D = 0:W = 0:S = 0:HB = 0:BD = 0:T = 0:BT = 0:H = 0:FX = 0:FY = 0:CP = 0:SP = 0
40 GOSUB 1000
50 PX = 2.5:PY = 2.5:PA = 0:ST = 0.15
60 FOV = 1.047
70 FOR S = 0 TO 39
80 O = - (FOV / 2) + (S / 39) * FOV
90 CO(S) = COS (O):SN(S) = SIN (O)
100 NEXT
110 CL(1) = 2:CL(2) = 14:CL(4) = 1:CL(5) = 3:CL(6) = 6
200 REM --- RENDER FRAME ---
210 CP = COS (PA):SP = SIN (PA)
220 FOR S = 0 TO 39
230 DX = (CP * CO(S) - SP * SN(S)) * ST:DY = (SP * CO(S) + CP * SN(S)) * ST
240 RX = PX:RY = PY:D = 0:HB = 0
250 RX = RX + DX:RY = RY + DY:D = D + ST
260 W = M( INT (RX), INT (RY))
270 IF W = 0 THEN 250
280 IF W < > 3 THEN 320
290 FX = RX - INT (RX) - 0.5:FY = RY - INT (RY) - 0.5
300 IF HB = 0 AND FX * FX + FY * FY < 0.04 THEN HB = 1:BD = D
310 GOTO 250
320 D = D * CO(S): IF D < 0.1 THEN D = 0.1
330 H = INT (15 / D): IF H > 19 THEN H = 19
340 T = 19 - H:BT = 19 + H
350 IF T > 0 THEN COLOR= 5: VLIN 0,T - 1 AT S
360 IF BT < 39 THEN COLOR= 15: VLIN BT + 1,39 AT S
370 COLOR= CL(W): VLIN T,BT AT S
380 IF HB = 0 THEN 420
390 BD = BD * CO(S): IF BD < 0.1 THEN BD = 0.1
400 H = INT (15 / BD): IF H > 19 THEN H = 19
405 BT = 19 + H:T = BT - INT (H * 2 / 3)
410 COLOR= 12: VLIN T,BT AT S
420 NEXT S
430 VTAB 21: PRINT "X=";INT (PX * 10) / 10;" Y="; INT (PY * 10) / 10;" DIR="; INT (PA * 57.3);" DEG    "
440 VTAB 22: PRINT "W/S=MOVE A/D=TURN Q=QUIT";
500 REM --- INPUT ---
510 GET A$
520 IF ASC (A$) > 96 THEN A$ = CHR$ ( ASC (A$) - 32)
530 IF ASC (A$) = 8 THEN A$ = "A"
540 IF ASC (A$) = 21 THEN A$ = "D"
550 IF A$ = "A" THEN PA = PA - 0.25: GOTO 200
560 IF A$ = "D" THEN PA = PA + 0.25: GOTO 200
570 IF A$ = "Q" THEN TEXT : HOME : END
580 IF A$ = "W" THEN NX = PX + CP * 0.5:NY = PY + SP * 0.5: GOTO 610
590 IF A$ = "S" THEN NX = PX - CP * 0.5:NY = PY - SP * 0.5: GOTO 610
600 GOTO 510
610 W = M( INT (NX), INT (NY))
620 IF W = 2 THEN 2000
630 IF W = 0 THEN PX = NX:PY = NY: GOTO 200
640 IF M( INT (NX), INT (PY)) = 0 THEN PX = NX: GOTO 200
650 IF M( INT (PX), INT (NY)) = 0 THEN PY = NY: GOTO 200
660 GOTO 510
1000 REM --- LOAD MAP DATA ---
1010 FOR Y = 1 TO 10: FOR X = 1 TO 10
1020 READ V:M(X,Y) = V
1030 NEXT X,Y: RETURN
1040 DATA 4,4,4,4,4,4,4,4,4,4
1050 DATA 4,0,0,0,0,0,0,0,0,5
1060 DATA 4,0,0,0,6,0,0,0,0,5
1070 DATA 4,0,0,3,6,3,0,0,0,5
1080 DATA 4,0,6,6,6,6,6,0,0,5
1090 DATA 4,0,0,3,6,3,0,0,0,5
1100 DATA 4,0,0,0,6,0,0,0,0,5
1110 DATA 4,0,1,0,0,0,0,1,0,5
1120 DATA 4,0,0,0,0,0,0,0,0,5
1130 DATA 4,1,1,1,2,1,1,1,1,5
2000 TEXT : HOME : VTAB 10: HTAB 14: PRINT "YOU ESCAPED!": END
